# ----------------------------------------------------------------------
# Frontend build-time configuration.
# Copy to `.env` for local dev, or set as repository variables in
# GitHub Actions for production builds.
# ----------------------------------------------------------------------

# Lambda Function URL of the deployed `infra/` stack (output `ApiUrl`).
# When unset, the leaderboard UI shows the Famous Algorithms table only
# and silently disables the Submit Score button — useful for `vite dev`
# when you don't have a backend running.
#
# Example: PUBLIC_API_URL=https://abc123xyz.lambda-url.us-west-2.on.aws
PUBLIC_API_URL=
