{
	"compilerOptions": {
		"target": "es2022",
		"module": "es2022",
		"moduleResolution": "bundler",
		"lib": ["es2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"types": ["node"]
	},
	"include": ["./**/*.ts"]
}
